{
  "name": "tact",
  "version": "1.0.7",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tact": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "tsx watch src/cli.ts start --cwd examples/basic",
    "start": "tsx src/cli.ts start --cwd examples/basic",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "keywords": [
    "telegram",
    "claude",
    "bot",
    "ai",
    "assistant"
  ],
  "author": "",
  "license": "ISC",
  "description": "Telegram bot that invokes Claude Code as a personal assistant",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "nodejs-whisper": "^0.2.9",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
